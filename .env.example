# =====================================================
# RAILWAY DEPLOYMENT ENVIRONMENT VARIABLES
# =====================================================
# Copy this file and set values for each service in Railway's dashboard.
# DO NOT commit actual values to version control.

# =====================================================
# BACKEND SERVICE (Flask)
# =====================================================
# Database URL (Railway provides this automatically for Railway Postgres)
DATABASE_URL=postgresql://user:password@host:5432/database

# Secret key for Flask sessions (generate a random string)
SECRET_KEY=your-super-secret-key-change-this

# JWT Secret key for token signing (generate a random string)
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# Email service configuration (optional)
EMAIL_SENDER_ADDRESS=your-email@gmail.com
EMAIL_SENDER_PASSWORD=your-app-password

# =====================================================
# RAG SERVICE (FastAPI)
# =====================================================
# OpenAI API key for embeddings and LLM
OPENAI_API_KEY=sk-your-openai-api-key

# Frontend URLs for CORS (comma-separated for multiple URLs)
FRONTEND_URL=https://your-frontend.railway.app
FRONTEND_URLS=https://your-frontend.railway.app,http://localhost:5173

# =====================================================
# FRONTEND SERVICE (React/Vite)
# =====================================================
# These are BUILD-TIME variables - set them in Railway as build args
# VITE_BACKEND_URL=https://your-backend.railway.app
# VITE_RAG_URL=https://your-rag.railway.app

# Cloudinary configuration (optional, for image uploads)
# VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
# VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# =====================================================
# NOTES FOR RAILWAY DEPLOYMENT
# =====================================================
# 1. Create separate Railway services for: backend, rag, frontend
# 2. Each service gets its own PORT automatically from Railway
# 3. Set environment variables in each service's settings
# 4. For frontend, VITE_ variables must be set as build arguments
#    because they're baked into the static build at compile time
# 5. Use Railway's internal networking for service-to-service calls:
#    - Internal URLs: backend.railway.internal:$PORT
#    - Public URLs: Use the generated Railway domain for frontend access
# 6. Railway Postgres provides DATABASE_URL automatically when linked
